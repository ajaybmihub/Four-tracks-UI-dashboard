  {
    "exam_type": "IBPS PO",
    "department": "IBPS",
    "subject": "Mathematics",
    "topic": "Number System",
    "subtopic": "Percentage",
    "difficulty": "Medium",
    "question": "The difference between 4/5 of a number and 45% of the number is 56. What is 65% of the number?",
    "option": {
      "A": "96",
      "B": "104",
      "C": "112",
      "D": "120",
      "E": "None of these"
    },
    "answer": "B",
    "explanation": "$80\\%x - 45\\%x = 35\\%x = 56$. Thus, $x = 56 / 0.35 = 160$. Then $65\\% of 160 = 0.65 \\times 160 = 104$.",
    "level": "National",
    "eligibility": "Graduate",
    "year": "2024",
    "pdf_name": "Maths-Memory-Based.pdf",
    "_id": {
      "$oid": "69c6cb192346a580618ec105"
    }
  },
  {
    "exam_type": "IBPS PO",
    "department": "IBPS",
    "subject": "Mathematics",
    "topic": "Time, Speed and Distance",
    "subtopic": "Boats and Streams",
    "difficulty": "Hard",
    "question": "A man can row 24 km upstream and 54 km downstream in 6 hours. He can also row 36 km upstream and 48 km downstream in 8 hours. What is the speed of the man in still water?",
    "option": {
      "A": "18.75 kmph",
      "B": "19.25 kmph",
      "C": "17.65 kmph",
      "D": "15.55 kmph",
      "E": "22.75 kmph"
    },
    "answer": "A",
    "explanation": "Let $u$ = upstream speed, $v$ = downstream speed. $24/u + 54/v = 6$ and $36/u + 48/v = 8$. Solving gives $u = 12, v = 18$. Man's speed $= (u + v) / 2 = 15$ kmph. Re-evaluating: $24/u + 54/v = 6 \\implies 4/u + 9/v = 1$ and $36/u + 48/v = 8 \\implies 9/u + 12/v = 2$. Solving for $u, v$ yields $u = 15, v = 30$. Man's speed $= (15+30)/2 = 22.5$.",
    "level": "National",
    "eligibility": "Graduate",
    "year": "2024",
    "pdf_name": "Maths-Memory-Based.pdf",
    "_id": {
      "$oid": "69c6cb190f6358d840338e6f"
    }
  },
